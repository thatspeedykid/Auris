{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Auris",
  "version": "0.1.0-alpha",
  "identifier": "com.privacychase.auris",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Auris",
        "width": 900,
        "height": 620,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/tray.png",
      "iconAsTemplate": false,
      "menuOnLeftClick": false,
      "tooltip": "Auris — by PrivacyChase"
    },
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "PrivacyChase",
    "copyright": "Copyright © 2026 PrivacyChase. DSP engine © FxSound (AGPL v3).",
    "licenseFile": "../LICENSE",
    "windows": {
      "digestAlgorithm": "sha256",
      "certificateThumbprint": null,
      "timestampUrl": "http://timestamp.digicert.com",
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "oneclick": false,
        "allowToChangeInstallationDirectory": true,
        "installMode": "perMachine"
      }
    }
  }
}
